# Database (Railway auto-provides DATABASE_URL; normalized to asyncpg in config)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ashfordbriggs

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic (server-side proxy for AI blog generation)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Public site origin, no trailing slash (used to build absolute URLs in the
# generated /sitemap.xml). Change this when deploying under a different domain.
SITE_URL=https://ashfordbriggs.com

# App
DEBUG=false
APP_NAME=Ashford & Briggs API
